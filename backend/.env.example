# Copy this file to .env and fill in values as needed.
# If GEMINI_API_KEY is left empty, the backend automatically runs in deterministic
# "mock" mode (local embeddings + extractive answers) so the stack works with zero config.

GEMINI_API_KEY=
PORT=4000
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
